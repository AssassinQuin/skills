# ============================================================
# one-search-mcp (官方镜像直接使用)
# ============================================================
# 官方镜像: ghcr.io/yokingma/one-search-mcp:latest
# 基础: mcr.microsoft.com/playwright (内置 Chromium)
# 平台: linux/amd64 only（Apple Silicon 需通过 Rosetta 2 模拟）
# 工具: one_search, one_scrape, one_map, one_extract
# 搜索引擎: searxng, duckduckgo, tavily, bing, google, zhipu, exa, bocha, local
# ============================================================
# 官方镜像已内置 Chromium，无需额外安装。
# 此 Dockerfile 仅为文档记录用途，实际直接拉取官方镜像即可：
#   docker pull --platform linux/amd64 ghcr.io/yokingma/one-search-mcp:latest
# ============================================================

FROM --platform=linux/amd64 ghcr.io/yokingma/one-search-mcp:latest
